<?xml version="1.0" encoding="UTF-8"?>
<!--
  Шаблон для ключей. Скопируйте этот файл в Localee/Secrets.plist
  и впишите свой ключ — настоящий Secrets.plist в git не попадает.

  Ключ MapKit Mobile SDK берётся здесь: https://developer.tech.yandex.ru
  Нужен именно MapKit SDK, а не JavaScript API (тот, что для сайта).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>YandexMapKitKey</key>
	<string>ВСТАВЬТЕ_КЛЮЧ</string>
</dict>
</plist>
